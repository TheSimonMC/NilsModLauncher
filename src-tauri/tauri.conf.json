{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NilsMod Launcher",
  "version": "1.0.1",
  "identifier": "net.nilsmod.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NilsMod Launcher",
        "width": 980,
        "height": 680,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "copyright": "NilsMod",
    "category": "Game",
    "shortDescription": "NilsMod profile installer",
    "longDescription": "Installs and updates NilsMod Fabric profiles for the official Minecraft Launcher."
  }
}
